# Kung Fu Chess — client-side integrations.
# Copy this file to .env (git-ignored) and fill in your values.

# Which LLM provider powers the AI bot difficulty in the offline lobby.
# Options: groq (default), openai. Switching providers is this line plus the
# matching API key below — no code changes.
# LLM_PROVIDER=groq

# Groq (default provider). Create a key at https://console.groq.com/keys
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI (set LLM_PROVIDER=openai). Create a key at https://platform.openai.com/api-keys
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
